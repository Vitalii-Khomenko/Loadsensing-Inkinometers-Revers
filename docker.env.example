# Copy this file to .env only when the defaults do not match the Linux host.
# Obtain the values with: id -u; id -g; getent group dialout
TIL90_UID=1000
TIL90_GID=1000
TIL90_DIALOUT_GID=20
TIL90_HTTP_PORT=8765

# Required only for compose.write.yaml. The binary is intentionally not in Git.
# Use an absolute path to the exact 124288-byte firmware 2.81 file.
TIL90_FIRMWARE_PATH=/absolute/path/to/LSG_TIL90_v2_81.bin
